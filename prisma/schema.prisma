// This file is the source of truth for the database schema.
// Run `prisma migrate dev` to apply changes once DATABASE_URL is configured.
//
// Note on UserProgram.isActive uniqueness:
// We cannot use @@unique([userId, isActive]) because it would prevent a user
// from having more than one inactive program. Instead, a partial unique index
// is applied via a raw SQL migration after the initial migrate:
//   CREATE UNIQUE INDEX "UserProgram_userId_isActive_partial_idx"
//   ON "UserProgram" ("userId") WHERE "isActive" = true;

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
}

enum ExerciseGroupType {
  STANDARD
  SUPERSET
}

// ---------------------------------------------------------------------------
// Auth / User
// ---------------------------------------------------------------------------

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  avatarUrl  String?
  provider   String
  providerId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userPrograms    UserProgram[]
  workoutSessions WorkoutSession[]

  @@unique([provider, providerId])
}

// ---------------------------------------------------------------------------
// Program library (immutable definitions)
// ---------------------------------------------------------------------------

model Program {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  weeks        ProgramWeek[]
  userPrograms UserProgram[]
}

model ProgramWeek {
  id         String @id @default(cuid())
  programId  String
  weekNumber Int

  program Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  days    ProgramDay[]

  @@unique([programId, weekNumber])
}

model ProgramDay {
  id            String  @id @default(cuid())
  programWeekId String
  dayNumber     Int
  name          String?
  warmUp        String?

  programWeek    ProgramWeek     @relation(fields: [programWeekId], references: [id], onDelete: Cascade)
  exerciseGroups ExerciseGroup[]

  @@unique([programWeekId, dayNumber])
}

model ExerciseGroup {
  id           String            @id @default(cuid())
  programDayId String
  order        Int
  type         ExerciseGroupType @default(STANDARD)
  restSeconds  Int?

  programDay ProgramDay        @relation(fields: [programDayId], references: [id], onDelete: Cascade)
  exercises  ProgramExercise[]

  @@unique([programDayId, order])
}

model Exercise {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  programExercises ProgramExercise[]
}

model ProgramExercise {
  id              String @id @default(cuid())
  exerciseGroupId String
  exerciseId      String
  order           Int

  exercise      Exercise      @relation(fields: [exerciseId], references: [id])
  exerciseGroup ExerciseGroup @relation(fields: [exerciseGroupId], references: [id], onDelete: Cascade)
  sets          ExerciseSet[]

  @@unique([exerciseGroupId, order])
}

model ExerciseSet {
  id                String  @id @default(cuid())
  programExerciseId String
  setNumber         Int
  reps              Int?
  weight            Float?
  rpe               Float?
  notes             String?

  programExercise ProgramExercise @relation(fields: [programExerciseId], references: [id], onDelete: Cascade)
  completedSets   CompletedSet[]

  @@unique([programExerciseId, setNumber])
}

// ---------------------------------------------------------------------------
// User progress (mutable)
// ---------------------------------------------------------------------------

model UserProgram {
  id          String   @id @default(cuid())
  userId      String
  programId   String
  isActive    Boolean  @default(false)
  currentWeek Int      @default(1)
  currentDay  Int      @default(1)
  startedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  workoutSessions WorkoutSession[]
}

model WorkoutSession {
  id            String        @id @default(cuid())
  userId        String
  userProgramId String
  weekNumber    Int
  dayNumber     Int
  status        SessionStatus @default(IN_PROGRESS)
  startedAt     DateTime      @default(now())
  completedAt   DateTime?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userProgram UserProgram @relation(fields: [userProgramId], references: [id], onDelete: Cascade)

  completedSets CompletedSet[]
}

model CompletedSet {
  id               String   @id @default(cuid())
  workoutSessionId String
  exerciseSetId    String
  reps             Int?
  weight           Float?
  rpe              Float?
  notes            String?
  completedAt      DateTime @default(now())

  workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exerciseSet    ExerciseSet    @relation(fields: [exerciseSetId], references: [id], onDelete: Cascade)
}
