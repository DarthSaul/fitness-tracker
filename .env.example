# Database — Supabase PostgreSQL
# Pooled connection for app runtime (port 6543, must include ?pgbouncer=true)
DATABASE_URL=
# Direct connection for migrations (port 5432, bypasses PgBouncer)
DIRECT_URL=

# Session — encrypts auth cookies (generate: openssl rand -base64 32)
NUXT_SESSION_PASSWORD=

# Google OAuth — Google Cloud Console > APIs & Services > Credentials
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
